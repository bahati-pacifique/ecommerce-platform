<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>COCOCE — Sign in to Admin</title>
  <meta name="description" content="COCOCE — Admin portal, COCOCE Kigali Rwanda, Laptops, Desktops, Computer accessories, Smart tv, projectors, discover what you want about digital assets near you at Kigali">
  <meta name="keywords" content="Laptops, Desktops, Memories, Storages, Servers, keyboards, Printers, Screens, Repair, Explore, Electronic, Digital, Kigali, Rwanda">
  <meta name="author" content="COCOCE RW">

  <meta property="og:image" content="https://cdn.cococe.rw/meta/cococe.png">
  <meta property="og:url" content="https://www.cococe.rw">
  <meta property="og:type" content="website">
  <meta property="og:title" content="Laptops, Printers, Accessories, Game consoles, Electronics, and much more, cococe, your wish our priority">
  <meta property="og:description" content="COCOCE Kigali Rwanda, Laptops, Desktops, Computer accessories, Smart tv, projectors, discover what you want about digital assets near you at Kigali">
  <meta property="og:logo" content="https://cdn.cococe.rw/meta/cococe.png" />

  <meta name="twitter:card" content="https://cdn.cococe.rw/meta/cococe.png">
  <meta property="twitter:domain" content="cococe.rw">
  <meta property="twitter:url" content="https://cococe.rw">
  <meta name="twitter:title" content="Laptops, Printers, Accessories, Game consoles, Electronics, and much more, cococe, your wish our priority">
  <meta name="twitter:description" content="COCOCE Kigali Rwanda, Laptops, Desktops, Computer accessories, Smart tv, projectors, discover what you want about digital assets near you at Kigali">

  <link rel="icon" href="/favicon.ico" type="image/x-icon">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
  
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/1.11.0/axios.min.js" integrity="sha512-h9644v03pHqrIHThkvXhB2PJ8zf5E9IyVnrSfZg8Yj8k4RsO4zldcQc4Bi9iVLUCCsqNY0b4WXVV4UB+wbWENA==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

  <link rel="stylesheet" href="/styles/components/notification.css">
  <link rel="stylesheet" href="/styles/main.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap');
    @import url('https://googleapis.com');
    @import url("https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css");
    *{
      box-sizing: border-box;
    }
    html, body {
      height: 100%;
      margin: 0;
      padding: 0;
    }

    body {
      background: #FDFDFC;
      font-family: 'Inter', sans-serif;
      scroll-behavior: smooth;
      display: flex;
      flex-direction: column;
    }

    .input-field {
      transition: all 0.2s ease;
      background: #f0f2f5;
      border: 1px solid transparent;
    }

    .input-field:focus {
      border-color: #ED1B24;
      background: white;
      box-shadow: 0 0 0 3px rgba(237, 27, 36, 0.08);
      outline: none;
    }

    .input-field.error {
      border-color: #ED1B24;
      background: #FFF5F5;
    }

    .signin-btn {
      background: #ED1B24;
      transition: all 0.2s ease;
    }

    .signin-btn:hover:not(:disabled) {
      background: #C9171F;
      transform: translateY(-1px);
      box-shadow: 0 4px 20px rgba(237, 27, 36, 0.3);
    }

    .signin-btn:active:not(:disabled) {
      transform: scale(0.98);
    }

    .signin-btn:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .auth-card {
      background: white;
      border-radius: 8px;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    }

    .auth-card:hover {
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
    }

    .server-message {
      transition: all 0.3s ease;
    }

    .server-message-container{
      display: flex;
      align-items: center;
      width: 100%;
    }

    .server-message-container .close {
      margin-left: auto;
      font-size: 1.5rem;
    }

    .server-message-container .close:hover{
      font-weight: 900;
    }

    .server-message.error {
      background: #FFF5F5;
      border-color: #ED1B24;
      color: #C9171F;
    }

    .server-message.warning {
      background: #fff7dc;
      border-color: #EED202;
      color: #998617;
    }

    .server-message.success {
      background: #F0FDF4;
      border-color: #22c55e;
      color: #166534;
    }

    @media (max-width: 768px) {
      .left-panel {
        display: none;
      }
      .card-logo {
        display: block !important;
      }
    }

    @media (min-width: 769px) {
      .card-logo {
        display: none !important;
      }
    }

    ::-webkit-scrollbar {
      width: 5px;
    }
    ::-webkit-scrollbar-track {
      background: #f1f1f1;
    }
    ::-webkit-scrollbar-thumb {
      background: #ED1B24;
      border-radius: 10px;
    }

    .divider-line {
      flex: 1;
      height: 1px;
      background: #e4e6eb;
    }

    .forgot-link {
      color: #222;
      font-size: 14px;
      font-weight: 500;
      transition: color 0.2s ease;
    }

    .forgot-link:hover {
      color: #111;
      text-decoration: underline;
    }

    .main-content {
      flex: 1 0 auto;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
      min-height: calc(100vh - 80px);
    }

    .app-footer {
      flex-shrink: 0;
      width: 100%;
      background: white;
      border-top: 1px solid #e5e7eb;
      padding: 1rem 1.5rem;
    }

    .app-footer-inner {
      max-width: 72rem;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }

    @media (min-width: 768px) {
      .app-footer-inner {
        flex-direction: row;
        justify-content: space-between;
      }
    }

    .footer-links {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem 1.5rem;
      font-size: 0.75rem;
      color: #9ca3af;
    }

    .footer-links a {
      transition: color 0.2s ease;
    }

    .footer-links a:hover {
      color: #ED1B24;
    }
  </style>
</head>
<script>
  const alertMsg = "<%= locals.message %>"
</script>
<body>

  <div class="main-content">
    <div class="w-full max-w-6xl mx-auto animate-fade-in">
      
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center min-h-[400px]">
        
        <div class="left-panel animate-slide-up">
          <div class="space-y-6">
            
            <div class="relative inline-block ml-8">
              <img src="<%- locals.logo %>" alt="Logo-brand" class="max-h-[100px]">
            </div>
            
            <%- locals.heroMessage %>
            
          </div>
        </div>
        
        <div class="auth-card p-6 md:p-8 animate-slide-up" style="animation-delay: 0.1s">
          
          <div class="card-logo text-center mb-6">
            <div class="relative inline-block">
              <img src="<%- locals.logo %>" alt="Logo-brand" class="max-h-[56px] md:max-h-[72px]">
            </div>
          </div>
          
          <div id="serverMessage" class="server-message hidden mb-4 p-3 rounded-lg border text-sm font-medium" role="alert">
            <div class="server-message-container">
              <span id="messageText"></span>
              <button class="close"><i class="bi bi-x"></i></button>
            </div>
          </div>
          
          <form id="signinForm" class="space-y-4" novalidate>
            <input type="hidden" name="referer" id="referer" value="<%- locals.referer %>">
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">
                Email or username
              </label>
              <input 
                type="text" 
                id="email" 
                name="email"
                placeholder="Enter your email or username" 
                class="input-field w-full px-4 py-3 rounded-lg text-gray-900 placeholder-gray-500 transition"
                required
                autocomplete="email"
              >
            </div>
            
            <div>
              <div class="flex justify-between items-center mb-1.5">
                <label for="password" class="block text-sm font-medium text-gray-700">Password</label>
              </div>
              <input 
                type="password" 
                id="password" 
                name="password"
                placeholder="Enter your password" 
                class="input-field w-full px-4 py-3 rounded-lg text-gray-900 placeholder-gray-500 transition"
                required
                autocomplete="current-password"
              >
            </div>
            <div class="flex items-center w-full">
              <a href="#" id="forgotLink" class="forgot-link text-sm ml-auto">Forgot password?</a>
            </div>
            
            <button 
              type="submit" 
              id="signinBtn"
              class="signin-btn w-full py-3 rounded-lg text-white font-semibold text-base transition"
            >
              Sign in
            </button>
          </form>
          
          <div class="flex items-center gap-3 my-4">
            <div class="divider-line"></div>
            <span class="text-xs text-gray-400 font-medium uppercase tracking-wider">or</span>
            <div class="divider-line"></div>
          </div>
          
          <button 
            id="ssoBtn"
            class="flex items-center justify-center gap-3 w-full py-2.5 rounded-lg bg-gray-50 border border-gray-200 text-gray-700 font-semibold text-sm transition hover:bg-gray-100 hover:border-gray-300"
          >
            <span class="text-gray-500 text-lg">
              <i class="bi bi-key-fill"></i>
            </span> Sign in with SSO
          </button>
          
          <p class="text-center text-xs text-gray-400 mt-5">
            By continuing, you agree to our 
            <a href="/terms" class="text-brand hover:underline transition">Terms</a> &amp; 
            <a href="/privacy-policy" class="text-brand hover:underline transition">Privacy Policy</a>
          </p>
        </div>
      </div>
    </div>
  </div>

  <footer class="app-footer">
    <div class="app-footer-inner">
      <div class="flex items-center gap-3">
        <a href="/" class="flex items-center -gap-1 text-sm">
          <img src="/images/logos/fav.png" alt="Cococe" class="max-h-[24px]">
          <span class="font-bold">COCOCE</span>
        </a>
        <span class="text-xs text-gray-400">© 2026</span>
      </div>
      <div class="footer-links">
        <a href="/docs/cococe-administration-privacy" class="hover:text-brand transition">Privacy</a>
        <a href="/docs/cococe-administration-terms" class="hover:text-brand transition">Terms</a>
        <a href="mailto:help@cococe.rw" class="hover:text-brand transition">Support</a>
        <a href="/admin/administration/status" class="hover:text-brand transition">Status</a>
      </div>
    </div>
  </footer>

  <script src="/scripts/components/notification.js"></script>
  <script src="/scripts/auth.js"></script>

</body>

</html>