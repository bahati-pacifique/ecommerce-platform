<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>COCOCE — <%=locals.title%></title>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">

  <meta name="description" content="COCOCE — Admin portal, COCOCE Kigali Rwanda, Laptops, Desktops, Computer accessories, Smart tv, projectors, discover what you want about digital assets near you at Kigali">
  <meta name="keywords" content="Laptops, Desktops, Memories, Storages, Servers, keyboards, Printers, Screens, Repair, Explore, Electronic, Digital, Kigali, Rwanda">
  <meta name="author" content="COCOCE RW">

  <meta property="og:image" content="https://cdn.cococe.rw/meta/cococe.png">
  <meta property="og:url" content="https://www.cococe.rw">
  <meta property="og:type" content="website">
  <meta property="og:title" content="Laptops, Printers, Accessories, Game consoles, Electronics, and much more, cococe, your wish our priority">
  <meta property="og:description" content="COCOCE Kigali Rwanda, Laptops, Desktops, Computer accessories, Smart tv, projectors, discover what you want about digital assets near you at Kigali">
  <meta property="og:logo" content="https://cdn.cococe.rw/meta/cococe.png" />

  <meta name="twitter:card" content="https://cdn.cococe.rw/meta/cococe.png">
  <meta property="twitter:domain" content="cococe.rw">
  <meta property="twitter:url" content="https://cococe.rw">
  <meta name="twitter:title" content="Laptops, Printers, Accessories, Game consoles, Electronics, and much more, cococe, your wish our priority">
  <meta name="twitter:description" content="COCOCE Kigali Rwanda, Laptops, Desktops, Computer accessories, Smart tv, projectors, discover what you want about digital assets near you at Kigali">

  <link rel="icon" href="/favicon.ico" type="image/x-icon">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />

  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/1.11.0/axios.min.js" integrity="sha512-h9644v03pHqrIHThkvXhB2PJ8zf5E9IyVnrSfZg8Yj8k4RsO4zldcQc4Bi9iVLUCCsqNY0b4WXVV4UB+wbWENA==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

  <link rel="stylesheet" href="/styles/components/notification.css">
  <link rel="stylesheet" href="/styles/main.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap');

    html,
    body {
      height: 100%;
      margin: 0;
      padding: 0;
    }

    body {
      background: #FDFDFC;
      font-family: 'Inter', sans-serif;
      scroll-behavior: smooth;
      display: flex;
      flex-direction: column;
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar {
      width: 5px;
    }

    ::-webkit-scrollbar-track {
      background: #f1f1f1;
    }

    ::-webkit-scrollbar-thumb {
      background: #ED1B24;
      border-radius: 10px;
    }

    /* Dots pattern background */
    .dots-bg {
      background-image: radial-gradient(circle, rgba(237, 27, 36, 0.06) 1.5px, transparent 1.5px);
      background-size: 24px 24px;
      background-position: 0 0;
    }

    /* Main content wrapper - pushes footer to bottom */
    .main-content {
      flex: 1 0 auto;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
      min-height: calc(100vh - 60px);
    }

    /* Footer - absolutely positioned at bottom */
    .app-footer {
      flex-shrink: 0;
      width: 100%;
      background: white;
      border-top: 1px solid #e5e7eb;
      padding: 0.75rem 1.5rem;
    }

    .app-footer-inner {
      max-width: 72rem;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }

    @media (min-width: 768px) {
      .app-footer-inner {
        flex-direction: row;
        justify-content: space-between;
      }
    }

    .footer-links {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem 1.5rem;
      font-size: 0.75rem;
      color: #9ca3af;
    }

    .footer-links a {
      transition: color 0.2s ease;
    }

    .footer-links a:hover {
      color: #ED1B24;
    }

    /* Animated lock icon */
    .lock-icon-wrapper {
      position: relative;
      display: inline-block;
    }

    .lock-icon-wrapper .pulse-ring {
      position: absolute;
      inset: -20px;
      border-radius: 50%;
      border: 2px solid rgba(237, 27, 36, 0.2);
      animation: pulseRing 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    .lock-icon-wrapper .pulse-ring:nth-child(2) {
      animation-delay: 0.5s;
      inset: -35px;
      border-color: rgba(237, 27, 36, 0.1);
    }

    /* Status badge */
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 16px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      background: #FEE2E3;
      color: #ED1B24;
      border: 1px solid rgba(237, 27, 36, 0.2);
    }

    /* Animated background shapes */
    .bg-shape {
      position: absolute;
      border-radius: 50%;
      filter: blur(60px);
      opacity: 0.12;
      pointer-events: none;
    }

    /* Minimal button */
    .btn-primary {
      background: #ED1B24;
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 28px;
      border-radius: 12px;
      color: white;
      font-weight: 600;
      font-size: 15px;
      text-decoration: none;
    }

    .btn-primary:hover {
      background: #C9171F;
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(237, 27, 36, 0.3);
    }

    .btn-primary:active {
      transform: scale(0.96);
    }

    .btn-outline {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 28px;
      border-radius: 12px;
      color: #4B5563;
      font-weight: 600;
      font-size: 15px;
      text-decoration: none;
      border: 2px solid #e5e7eb;
      background: white;
      transition: all 0.3s ease;
    }

    .btn-outline:hover {
      border-color: #ED1B24;
      color: #ED1B24;
      background: #FFF5F5;
      transform: translateY(-2px);
    }
  </style>
</head>

<body class="dots-bg">

  <nav class="px-4 md:px-10 py-3 border-b border-gray-100 bg-white/80 backdrop-blur-sm">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
      <a href="/" class="relative inline-block group">
        <img src="/images/logos/cococe.png" alt="Logo-brand" class="max-w-[120px] md:max-w-[100px]">
      </a>
      <span class="status-badge text-xs"><i class="bi bi-slash-circle"></i> <%=locals.title%></span>
    </div>
  </nav>

  <div class="main-content relative overflow-hidden">

    <div class="bg-shape w-72 h-72 bg-brand top-[-10%] left-[-5%] animate-float"></div>
    <div class="bg-shape w-96 h-96 bg-brand/50 bottom-[-10%] right-[-5%] animate-float" style="animation-delay: 2s;"></div>
    <div class="bg-shape w-48 h-48 bg-brand-light top-1/2 left-1/3 animate-float" style="animation-delay: 4s;"></div>

    <div class="w-full max-w-2xl text-center animate-fade-in px-4">

      <div class="lock-icon-wrapper mb-6">
        <div class="pulse-ring"></div>
        <div class="pulse-ring"></div>
        <div class="w-20 h-20 bg-brand-light rounded-full flex items-center justify-center mx-auto relative animate-shake">
          <svg class="w-10 h-10 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6" />
          </svg>
        </div>
      </div>

      <h1 class="text-3xl mt-3 md:text-4xl font-bold text-gray-900 mb-3 animate-slide-up">
        Hey, <span class="text-brand"><%=locals.user.username%></span>
      </h1>

      <p class="text-gray-500 text-base md:text-lg max-w-lg mx-auto mb-6 animate-slide-up p-4 mt-3" style="animation-delay: 0.1s">
        <%=locals.message%>
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 md:gap-8 animate-slide-up" style="animation-delay: 0.2s">
        <a href="/" class="btn-primary">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z" />
          </svg>
          Go Home
        </a>
        <form action="/logout" method="post">
          <button type="submit" class="btn-outline cursor-pointer">
            Logout <i class="bi bi-box-arrow-right"></i>
          </button>
        </form>
      </div>

      <p class="text-xs text-gray-400 mt-6 animate-slide-up" style="animation-delay: 0.25s">
        Need access? <a href="mailto:support@cococe.rw" class="text-brand hover:underline transition font-medium"> contact our support team</a>
      </p>
    </div>
  </div>

  <footer class="app-footer">
    <div class="app-footer-inner">
      <div class="flex items-center gap-3">
        <span class="text-sm font-bold text-brand">COCOCE</span>
        <span class="text-xs text-gray-400">© 2026 — Authorization Required</span>
      </div>
      <div class="footer-links">
        <a href="/privacy" class="hover:text-brand transition">Privacy</a>
        <a href="/terms" class="hover:text-brand transition">Terms</a>
        <a href="mailto:support@cococe.rw" class="hover:text-brand transition">Support</a>
      </div>
    </div>
  </footer>

</body>

</html>