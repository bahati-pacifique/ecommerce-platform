<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>COCOCE — Admin Dashboard</title>
  <meta name="description" content="COCOCE — Admin portal, COCOCE Kigali Rwanda, Laptops, Desktops, Computer accessories, Smart tv, projectors, discover what you want about digital assets near you at Kigali">
  <meta name="keywords" content="Laptops, Desktops, Memories, Storages, Servers, keyboards, Printers, Screens, Repair, Explore, Electronic, Digital, Kigali, Rwanda">
  <meta name="author" content="COCOCE RW">

  <meta property="og:image" content="https://cdn.cococe.rw/meta/cococe.png">
  <meta property="og:url" content="https://www.cococe.rw">
  <meta property="og:type" content="website">
  <meta property="og:title" content="Laptops, Printers, Accessories, Game consoles, Electronics, and much more, cococe, your wish our priority">
  <meta property="og:description" content="COCOCE Kigali Rwanda, Laptops, Desktops, Computer accessories, Smart tv, projectors, discover what you want about digital assets near you at Kigali">
  <meta property="og:logo" content="https://cdn.cococe.rw/meta/cococe.png" />

  <meta name="twitter:card" content="https://cdn.cococe.rw/meta/cococe.png">
  <meta property="twitter:domain" content="cococe.rw">
  <meta property="twitter:url" content="https://cococe.rw">
  <meta name="twitter:title" content="Laptops, Printers, Accessories, Game consoles, Electronics, and much more, cococe, your wish our priority">
  <meta name="twitter:description" content="COCOCE Kigali Rwanda, Laptops, Desktops, Computer accessories, Smart tv, projectors, discover what you want about digital assets near you at Kigali">

  <link rel="icon" href="/favicon.ico" type="image/x-icon">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
  <script src="https://code.jquery.com/jquery-4.0.0.js" integrity="sha256-9fsHeVnKBvqh3FB2HYu7g2xseAZ5MlN6Kz/qnkASV8U=" crossorigin="anonymous"></script>

  <link rel="stylesheet" href="/styles/components/notification.css">
  <link rel="stylesheet" href="/styles/main.css">

  <!-- Chart.js for charts -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap');
    @import url("https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css");

    body {
      background: #FDFDFC;
      font-family: 'Inter', sans-serif;
      scroll-behavior: smooth;
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar {
      width: 5px;
    }

    ::-webkit-scrollbar-track {
      background: #f1f1f1;
    }

    ::-webkit-scrollbar-thumb {
      background: #ED1B24;
      border-radius: 10px;
    }

    /* Sidebar */
    .sidebar {
      background: white;
      border-right: 1px solid #e5e7eb;
      height: 100vh;
      position: sticky;
      top: 0;
      overflow-y: auto;
      overflow-x: hidden;
      transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      width: 264px;
      flex-shrink: 0;
    }

    .sidebar.collapsed {
      width: 72px;
    }

    .sidebar::-webkit-scrollbar {
      width: 3px;
    }

    .sidebar::-webkit-scrollbar-track {
      background: transparent;
    }

    .sidebar::-webkit-scrollbar-thumb {
      background: #ED1B24;
      border-radius: 10px;
    }

    /* Sidebar nav items */
    .sidebar-link {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 16px;
      border-radius: 12px;
      color: #6B7280;
      font-weight: 500;
      font-size: 14px;
      transition: all 0.2s ease;
      cursor: pointer;
      position: relative;
      text-decoration: none;
      white-space: nowrap;
      overflow: hidden;
    }

    .sidebar.collapsed .sidebar-link {
      padding: 10px 18px;
      justify-content: center;
    }

    .sidebar.collapsed .sidebar-link .link-text {
      display: none;
    }

    .sidebar.collapsed .sidebar-link .badge {
      display: none;
    }

    .sidebar.collapsed .sidebar-link .icon {
      font-size: 22px;
      width: 32px;
      text-align: center;
    }

    .sidebar-link:hover {
      background: #F9FAFB;
      color: #1F2937;
    }

    .sidebar-link.active {
      background: #FEE2E3;
      color: #ED1B24;
      font-weight: 600;
    }

    .sidebar-link .icon {
      font-size: 20px;
      width: 28px;
      text-align: center;
      flex-shrink: 0;
    }

    .sidebar-link .badge {
      margin-left: auto;
      background: #ED1B24;
      color: white;
      font-size: 10px;
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 20px;
      flex-shrink: 0;
    }

    .sidebar-link .badge.amber {
      background: #F59E0B;
    }

    .sidebar-link .badge.green {
      background: #22C55E;
    }

    /* Sidebar Brand */
    .sidebar-brand {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 16px 20px;
      border-bottom: 1px solid #e5e7eb;
      transition: all 0.3s ease;
      overflow: hidden;
      white-space: nowrap;
    }

    .sidebar.collapsed .sidebar-brand {
      padding: 16px 18px;
      justify-content: center;
    }

    .sidebar.collapsed .sidebar-brand .brand-text {
      display: none;
    }

    .sidebar.collapsed .sidebar-brand .brand-badge {
      display: none;
    }

    .sidebar-brand .brand-text {
      font-size: 22px;
      font-weight: 900;
      letter-spacing: -0.5px;
      color: #ED1B24;
    }

    .sidebar-brand .brand-badge {
      font-size: 9px;
      font-weight: 700;
      background: #FEE2E3;
      color: #ED1B24;
      padding: 2px 8px;
      border-radius: 20px;
      border: 1px solid rgba(237, 27, 36, 0.2);
    }

    /* Sidebar Footer */
    .sidebar-footer {
      padding: 16px 20px;
      border-top: 1px solid #e5e7eb;
      transition: all 0.3s ease;
      overflow: hidden;
    }

    .sidebar.collapsed .sidebar-footer {
      padding: 16px 14px;
    }

    .sidebar.collapsed .sidebar-footer .user-info {
      display: none;
    }

    .sidebar.collapsed .sidebar-footer .avatar {
      margin: 0 auto;
    }

    /* Top bar */
    .top-bar {
      background: white;
      border-bottom: 1px solid #e5e7eb;
      padding: 12px 24px;
      position: sticky;
      top: 0;
      z-index: 40;
    }

    .top-bar-btn {
      transition: all 0.2s ease;
      background: white;
      border: 1px solid #e5e7eb;
      padding: 8px 16px;
      border-radius: 12px;
      font-size: 13px;
      font-weight: 500;
      color: #4B5563;
      cursor: pointer;
    }

    .top-bar-btn:hover {
      background: #F9FAFB;
      border-color: #D1D5DB;
    }

    /* Sidebar toggle button */
    .sidebar-toggle {
      transition: all 0.3s ease;
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      padding: 6px 10px;
      cursor: pointer;
      color: #6B7280;
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 13px;
    }

    .sidebar-toggle:hover {
      background: #F9FAFB;
      border-color: #D1D5DB;
    }

    .sidebar.collapsed .sidebar-toggle .toggle-text {
      display: none;
    }

    /* Modal overlay */
    .modal-overlay {
      background: rgba(0, 0, 0, 0.4);
      backdrop-filter: blur(8px);
      animation: fadeIn 0.3s ease-out;
    }

    .modal-content {
      animation: slideDown 0.3s ease-out;
      max-height: 80vh;
      overflow-y: auto;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
      }

      to {
        opacity: 1;
      }
    }

    @keyframes slideDown {
      from {
        opacity: 0;
        transform: translateY(-20px) scale(0.95);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    /* Stat card hover */
    .stat-card {
      transition: all 0.3s ease;
    }

    .stat-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.06);
    }

    /* Inventory item hover */
    .inventory-item {
      transition: all 0.2s ease;
    }

    .inventory-item:hover {
      background: #f9fafb;
      transform: translateX(4px);
    }

    /* Modal link items */
    .modal-link-item {
      transition: all 0.2s ease;
    }

    .modal-link-item:hover {
      background: #FEE2E3;
      transform: translateX(4px);
    }

    /* Chart container */
    .chart-container {
      position: relative;
      height: 280px;
    }

    @media (max-width: 640px) {
      .chart-container {
        height: 220px;
      }
    }

    /* Mobile sidebar overlay */
    .sidebar-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.4);
      z-index: 49;
    }

    .sidebar-overlay.active {
      display: block;
    }

    @media (max-width: 1023px) {
      .sidebar {
        position: fixed;
        left: 0;
        top: 0;
        bottom: 0;
        z-index: 50;
        transform: translateX(-100%);
        width: 280px;
        transition: transform 0.3s ease;
        box-shadow: 4px 0 20px rgba(0, 0, 0, 0.05);
      }

      .sidebar.mobile-open {
        transform: translateX(0);
      }

      .sidebar-overlay.active {
        display: block;
      }

      .sidebar-toggle {
        display: none !important;
      }

      .sidebar.collapsed {
        width: 280px !important;
      }

      .sidebar.collapsed .sidebar-link .link-text {
        display: inline !important;
      }

      .sidebar.collapsed .sidebar-link .badge {
        display: inline-block !important;
      }

      .sidebar.collapsed .sidebar-link {
        justify-content: flex-start !important;
        padding: 10px 16px !important;
      }

      .sidebar.collapsed .sidebar-brand .brand-text {
        display: inline !important;
      }

      .sidebar.collapsed .sidebar-brand .brand-badge {
        display: inline-block !important;
      }

      .sidebar.collapsed .sidebar-footer .user-info {
        display: block !important;
      }

      .sidebar.collapsed .sidebar-footer {
        padding: 16px 20px !important;
      }

      .sidebar.collapsed .sidebar-footer .avatar {
        margin: 0 !important;
      }
    }

    /* Hide scrollbar on mobile */
    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }

    .no-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>
</head>

<body class="bg-bg-soft">

  <!-- Sidebar Overlay for mobile -->
  <div id="sidebarOverlay" class="sidebar-overlay" onclick="closeMobileSidebar()"></div>

  <div class="flex min-h-screen">

    <!-- ========== SIDEBAR ========== -->
    <aside id="sidebar" class="sidebar">
      <div class="flex flex-col h-full">
        <!-- Sidebar Brand -->
        <div class="sidebar-brand">
          <img src="/images/logos/administration.png" alt="Logo-brand" class="max-h-[38px]">
          <!-- <span class="brand-badge">ADMIN</span> -->
        </div>

        <!-- Sidebar Navigation -->
        <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
          <!-- Home -->
          <a href="#" class="sidebar-link active" data-tab="home">
            <span class="icon"><i class="bi bi-house"></i></span>
            <span class="link-text">Dashboard</span>
          </a>

          <!-- Profile -->
          <a href="#" class="sidebar-link" data-tab="profile">
            <span class="icon"><i class="bi bi-person"></i></span>
            <span class="link-text">Admin Profile</span>
          </a>

          <!-- Business -->
          <a href="#" class="sidebar-link" data-tab="business">
            <span class="icon"><i class="bi bi-person-gear"></i></span>
            <span class="link-text">Business Profile</span>
          </a>

          <!-- Orders -->
          <a href="#" class="sidebar-link" data-tab="orders">
            <span class="icon"><i class="bi bi-receipt"></i></span>
            <span class="link-text">Orders</span>
            <span class="badge amber">48</span>
          </a>

          <!-- Inventory -->
          <a href="#" class="sidebar-link" data-tab="inventory">
            <span class="icon"><i class="bi bi-bar-chart-line"></i></span>
            <span class="link-text">Inventory</span>
            <span class="badge">23</span>
          </a>

          <!-- Customers -->
          <a href="#" class="sidebar-link" data-tab="customers">
            <span class="icon"><i class="bi bi-people-fill"></i></span>
            <span class="link-text">Customers</span>
            <span class="badge green">+12</span>
          </a>

          <!-- Analytics -->
          <a href="#" class="sidebar-link" data-tab="analytics">
            <span class="icon"><i class="bi bi-graph-down"></i></span>
            <span class="link-text">Analytics</span>
          </a>

          <!-- Marketing -->
          <a href="#" class="sidebar-link" data-tab="marketing">
            <span class="icon"><i class="bi bi-badge-ad"></i></span>
            <span class="link-text">Marketing</span>
          </a>

          <!-- Settings -->
          <a href="#" class="sidebar-link" data-tab="settings">
            <span class="icon"><i class="bi bi-gear"></i></span>
            <span class="link-text">Settings</span>
          </a>

          <div class="border-t border-gray-100 my-3"></div>

          <!-- Quick Actions (in sidebar) -->
          <a href="#" class="sidebar-link" data-tab="quick-actions">
            <span class="icon"><i class="bi bi-list"></i></span>
            <span class="link-text">Quick Actions</span>
          </a>

          <a href="#" class="sidebar-link" data-tab="help">
            <span class="icon"><i class="bi bi-info-circle"></i></span>
            <span class="link-text">Help & Support</span>
          </a>
        </nav>

        <!-- Sidebar Footer -->
        <div class="sidebar-footer">
          <div class="flex items-center gap-3">
            <div class="avatar w-8 h-8 rounded-full bg-brand-light flex items-center justify-center text-brand font-bold text-sm flex-shrink-0">
              <%- locals.user.username.charAt(0) %>
            </div>
            <div class="user-info">
              <p class="text-sm font-medium text-gray-800"><%-locals.user?.username%> — <%-locals.user?.type?.substring(0, 3)%></p>
              <p class="text-xs text-gray-400"><%- locals.user.email %></p>
            </div>
          </div>
        </div>
      </div>
    </aside>

    <!-- ========== MAIN CONTENT ========== -->
    <div class="flex-1 min-w-0">

      <!-- Top Bar -->
      <header class="top-bar">
        <div class="flex items-center justify-between">
          <!-- Left: Mobile hamburger + breadcrumb + toggle -->
          <div class="flex items-center gap-3">
            <button id="mobileMenuBtn" class="lg:hidden p-2 rounded-lg hover:bg-gray-100 transition">
              <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>

            <!-- Sidebar Toggle Button (desktop only) -->
            <button id="sidebarToggle" class="sidebar-toggle hidden lg:flex" title="Toggle sidebar">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />
              </svg>
              <!-- <span class="toggle-text text-sm">Collapse</span> -->
            </button>

            <span class="text-sm font-medium text-gray-700 hidden sm:block">Dashboard / <span id="currentTabLabel" class="text-brand">Home</span></span>
          </div>

          <!-- Right: Top bar actions -->
          <div class="flex items-center gap-2">
            <button id="topBarModalTrigger" class="top-bar-btn flex items-center gap-2">
              <span>☰</span>
              <span class="hidden sm:inline">Quick Actions</span>
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <button class="p-2 rounded-lg hover:bg-gray-100 transition relative">
              <span class="text-xl"><i class="bi bi-bell"></i></span>
              <span class="absolute -top-0.5 -right-0.5 w-2.5 h-2.5 bg-brand rounded-full border-2 border-white"></span>
            </button>
          </div>
        </div>
      </header>

      <!-- Main Content Area -->
      <main class="p-4 md:p-6 max-w-full">

        <!-- Tab Content: Home -->
        <div id="tab-home" class="tab-content">

          <!-- Stats Grid -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
            <div class="stat-card bg-white rounded-2xl p-5 border border-gray-100 shadow-sm">
              <div class="flex items-start justify-between">
                <div>
                  <p class="text-sm text-gray-500 font-medium">Total Sales</p>
                  <p class="text-2xl font-bold text-gray-900 mt-1">$124,892</p>
                  <p class="text-xs text-green-600 mt-1">↑ 12.5% from last month</p>
                </div>
                <div class="w-10 h-10 bg-brand-light rounded-xl flex items-center justify-center text-brand text-xl">💰</div>
              </div>
            </div>

            <div class="stat-card bg-white rounded-2xl p-5 border border-gray-100 shadow-sm">
              <div class="flex items-start justify-between">
                <div>
                  <p class="text-sm text-gray-500 font-medium">Total Orders</p>
                  <p class="text-2xl font-bold text-gray-900 mt-1">1,284</p>
                  <p class="text-xs text-gray-500 mt-1">48 pending</p>
                </div>
                <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center text-blue-500 text-xl">📦</div>
              </div>
            </div>

            <div class="stat-card bg-white rounded-2xl p-5 border border-gray-100 shadow-sm">
              <div class="flex items-start justify-between">
                <div>
                  <p class="text-sm text-gray-500 font-medium">Inventory Items</p>
                  <p class="text-2xl font-bold text-gray-900 mt-1">3,847</p>
                  <p class="text-xs text-amber-600 mt-1">⚠️ 23 low stock</p>
                </div>
                <div class="w-10 h-10 bg-amber-50 rounded-xl flex items-center justify-center text-amber-500 text-xl">📊</div>
              </div>
            </div>

            <div class="stat-card bg-white rounded-2xl p-5 border border-gray-100 shadow-sm">
              <div class="flex items-start justify-between">
                <div>
                  <p class="text-sm text-gray-500 font-medium">Total Stores</p>
                  <p class="text-2xl font-bold text-gray-900 mt-1">12</p>
                  <p class="text-xs text-gray-500 mt-1">8 active · 4 pending</p>
                </div>
                <div class="w-10 h-10 bg-purple-50 rounded-xl flex items-center justify-center text-purple-500 text-xl">🏪</div>
              </div>
            </div>
          </div>

          <!-- Charts Row -->
          <div class="grid md:grid-cols-2 gap-6 mb-6">
            <!-- Sales Chart -->
            <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm">
              <div class="flex items-center justify-between mb-4">
                <h3 class="text-sm font-semibold text-gray-700">Sales Overview</h3>
                <span class="text-xs text-gray-400">Last 7 days</span>
              </div>
              <div class="chart-container">
                <canvas id="salesChart"></canvas>
              </div>
            </div>

            <!-- Order Status Chart -->
            <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm">
              <div class="flex items-center justify-between mb-4">
                <h3 class="text-sm font-semibold text-gray-700">Order Status</h3>
                <span class="text-xs text-gray-400">Current</span>
              </div>
              <div class="chart-container">
                <canvas id="orderChart"></canvas>
              </div>
            </div>
          </div>

          <!-- Alerts & Inventory Section -->
          <div class="grid md:grid-cols-2 gap-6 mb-6">
            <!-- Alerts -->
            <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm">
              <h3 class="text-sm font-semibold text-gray-700 mb-4">⚠️ Alerts</h3>
              <div class="space-y-3">
                <div class="flex items-center gap-3 p-3 bg-red-50 rounded-xl border border-red-200">
                  <span class="text-xl">🔴</span>
                  <div class="flex-1">
                    <p class="text-sm font-medium text-red-700">Low Stock Alert</p>
                    <p class="text-xs text-red-600">5 items below minimum threshold</p>
                  </div>
                  <span class="text-xs font-semibold text-red-700">URGENT</span>
                </div>
                <div class="flex items-center gap-3 p-3 bg-amber-50 rounded-xl border border-amber-200">
                  <span class="text-xl">🟡</span>
                  <div class="flex-1">
                    <p class="text-sm font-medium text-amber-700">Old Stock Warning</p>
                    <p class="text-xs text-amber-600">12 items aging > 180 days</p>
                  </div>
                  <span class="text-xs font-semibold text-amber-700">ATTENTION</span>
                </div>
                <div class="flex items-center gap-3 p-3 bg-blue-50 rounded-xl border border-blue-200">
                  <span class="text-xl">🔵</span>
                  <div class="flex-1">
                    <p class="text-sm font-medium text-blue-700">Expiring Stock</p>
                    <p class="text-xs text-blue-600">8 items expiring in 30 days</p>
                  </div>
                  <span class="text-xs font-semibold text-blue-700">REVIEW</span>
                </div>
                <div class="flex items-center gap-3 p-3 bg-green-50 rounded-xl border border-green-200">
                  <span class="text-xl">🟢</span>
                  <div class="flex-1">
                    <p class="text-sm font-medium text-green-700">Stock Restocked</p>
                    <p class="text-xs text-green-600">34 items restocked this week</p>
                  </div>
                  <span class="text-xs font-semibold text-green-700">DONE</span>
                </div>
              </div>
            </div>

            <!-- Inventory by Category -->
            <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm">
              <h3 class="text-sm font-semibold text-gray-700 mb-4">📦 Inventory by Category</h3>
              <div class="space-y-3">
                <div class="inventory-item flex items-center justify-between p-3 rounded-xl border border-gray-100">
                  <div class="flex items-center gap-3">
                    <span class="text-xl">💻</span>
                    <div>
                      <p class="text-sm font-medium text-gray-800">Laptops</p>
                      <p class="text-xs text-gray-400">High-performance devices</p>
                    </div>
                  </div>
                  <span class="text-sm font-bold text-gray-900">100</span>
                </div>
                <div class="inventory-item flex items-center justify-between p-3 rounded-xl border border-gray-100">
                  <div class="flex items-center gap-3">
