  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap');
    @import url("https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css");

    body {
      background: #FDFDFC;
      font-family: 'Inter', sans-serif;
      scroll-behavior: smooth;
      overflow-x: hidden;
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar {
      width: 5px;
    }

    ::-webkit-scrollbar-track {
      background: #f1f1f1;
    }

    ::-webkit-scrollbar-thumb {
      background: #ED1B24;
      border-radius: 10px;
    }

    /* Card slider container with extra padding for hover effects */
    .card-slider-wrapper {
      overflow: hidden;
      border-radius: 16px;
      padding: 8px 0;
      /* Extra padding top and bottom for hover lift */
    }

    .card-slider {
      display: flex;
      transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      will-change: transform;
      padding: 4px 0;
      /* Additional padding for hover lift */
    }

    .account-card {
      flex: 0 0 100%;
      max-width: 100%;
      padding: 0 8px;
      transition: all 0.3s ease;
      cursor: pointer;
    }

    @media (min-width: 768px) {
      .account-card {
        flex: 0 0 50%;
        max-width: 50%;
        padding: 0 10px;
      }
    }

    @media (min-width: 1024px) {
      .account-card {
        flex: 0 0 33.333%;
        max-width: 33.333%;
        padding: 0 12px;
      }
    }

    .account-card-inner {
      background: white;
      border-radius: 16px;
      border: 1px solid #e5e7eb;
      padding: 24px;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      height: 100%;
      position: relative;
      overflow: hidden;
      min-height: 200px;
      /* Ensure card content doesn't overflow */
      display: flex;
      flex-direction: column;
    }

    .account-card-inner:hover {
      transform: translateY(-6px);
      border-color: #ED1B24;
      box-shadow: 0 12px 40px rgba(237, 27, 36, 0.12);
    }

    .account-card-inner.selected {
      border-color: #ED1B24;
      box-shadow: 0 8px 30px rgba(237, 27, 36, 0.15);
      background: #FFF5F5;
      transform: translateY(-4px);
    }

    .account-card-inner.selected::before {
      content: '✓ Selected';
      position: absolute;
      top: 12px;
      right: 12px;
      background: #ED1B24;
      color: white;
      font-size: 10px;
      font-weight: 600;
      padding: 4px 12px;
      border-radius: 20px;
      letter-spacing: 0.5px;
    }

    /* Ensure card content doesn't overflow */
    .account-card-inner p {
      flex: 1;
      overflow: hidden;
      text-overflow: ellipsis;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
    }

    /* Navigation dots */
    .dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: #d1d5db;
      border: none;
      cursor: pointer;
      transition: all 0.3s ease;
      padding: 0;
    }

    .dot.active {
      background: #ED1B24;
      width: 28px;
      border-radius: 5px;
    }

    .dot:hover:not(.active) {
      background: #9ca3af;
    }

    /* Navigation arrows */
    .nav-arrow {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: white;
      border: 1px solid #e5e7eb;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.3s ease;
      color: #4b5563;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    }

    .nav-arrow:hover:not(:disabled) {
      background: #ED1B24;
      color: white;
      border-color: #ED1B24;
      box-shadow: 0 4px 16px rgba(237, 27, 36, 0.25);
    }

    .nav-arrow:disabled {
      opacity: 0.3;
      cursor: not-allowed;
    }

    /* Badge styles */
    .type-badge {
      font-size: 10px;
      font-weight: 600;
      padding: 2px 10px;
      border-radius: 20px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      background: #DBEAFE;
      color: #1D4ED8;
    }

    .type-badge.admin {
      background: #FEE2E3;
      color: #ED1B24;
    }

    /* .type-badge.user {
      
    } */

    .type-badge.guest {
      background: #F3F4F6;
      color: #6B7280;
    }

    .type-badge.developer {
      background: #FCE7F3;
      color: #BE185D;
    }

    /* Hide scrollbar */
    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }

    .no-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    /* Fix for card overflow on hover */
    .card-slider-wrapper {
      overflow: hidden;
      border-radius: 16px;
      padding: 8px 4px;
    }

    /* Ensure slider container has enough space for hover lift */
    .card-slider {
      padding: 8px 0;
    }

    /* Account card container with extra bottom margin for hover */
    .account-card {
      padding-bottom: 4px;
    }

    /* Fix for mobile */
    @media (max-width: 640px) {
      .account-card-inner {
        min-height: 180px;
        padding: 20px;
      }
    }
  </style>
</head>

<script>
  const userAccounts = JSON.parse('<%- JSON.stringify(locals.accounts) %>');
