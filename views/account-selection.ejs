        <span>Go Home</span>
        <i class="bi bi-house font-bold"></i>
      </a>
      <p class="text-slate-500 mt-3 text-xs ml-auto">
        Contact our support Team <a class="text-brand hover:underline" href="mailto:support@cococe.rw">here</a>
      </p>
    </div>
  </main>



  <footer class="py-4 px-6 bg-white border-t border-gray-100">
