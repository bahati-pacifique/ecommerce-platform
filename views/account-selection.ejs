    <div class="bg-white max-w-[95%] md:max-w-[800px] md:min-w-[500px] px-3 md:px-8 py-3 flex flex-col items-center justify-center gap-3 border rounded-xl border-slate-300 text-xl <%-locals.accounts.length > 0 ? 'hidden' : ''%>">
      <h3 class="text-6xl md:text-8xl text-brand">
